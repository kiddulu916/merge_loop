# Supabase credentials for merge_count (Competitive Daily Expansion).
# Copy this file to `.env` (gitignored) and fill in real values.
# The Flutter app reads these via --dart-define at build/run time.
#
#   flutter run \
#     --dart-define=SUPABASE_URL=$SUPABASE_URL \
#     --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
#
# Find these in the Supabase dashboard:
#   Project Settings -> API  (URL + anon/publishable key)

# Project URL, e.g. https://abcdefghijklmnop.supabase.co
SUPABASE_URL=

# anon / publishable key (safe to ship in the client app)
SUPABASE_ANON_KEY=

# NOTE: the service_role (SECRET) key is NEVER stored here and NEVER committed.
# Supabase injects SUPABASE_SERVICE_ROLE_KEY into Edge Functions automatically
# (both in the cloud and via `supabase functions serve` against the local stack),
# so the replay-verification function gets it without manual handling.
